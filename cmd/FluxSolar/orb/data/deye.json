{
  "name": "Deye Hybrid Inverter",
  "uart": {
    "baud_rate": 9600,
    "data_bits": 8,
    "parity": "none",
    "stop_bits": 1
  },
  "modbus": {
    "slave_address": 1,
    "poll_interval_ms": 5000
  },
  "registers": [
    {
      "name": "pv1_total_power",
      "label": "PV1 Power",
      "address": 672,
      "function_code": 3,
      "value_type": "U_WORD",
      "unit": "W",
      "multiplier": 1
    },
    {
      "name": "pv2_total_power",
      "label": "PV2 Power",
      "address": 673,
      "function_code": 3,
      "value_type": "U_WORD",
      "unit": "W",
      "multiplier": 1
    },
    {
      "name": "measured_power",
      "label": "Grid Power",
      "address": 625,
      "function_code": 3,
      "value_type": "S_WORD",
      "unit": "W",
      "multiplier": 1
    },
    {
      "name": "total_consumption_power",
      "label": "Load Power",
      "address": 653,
      "function_code": 3,
      "value_type": "S_WORD",
      "unit": "W",
      "multiplier": 1
    },
    {
      "name": "battery_power",
      "label": "Battery Power",
      "address": 590,
      "function_code": 3,
      "value_type": "S_WORD",
      "unit": "W",
      "multiplier": 1
    },
    {
      "name": "battery_level",
      "label": "Battery SOC",
      "address": 588,
      "function_code": 3,
      "value_type": "U_WORD",
      "unit": "%",
      "multiplier": 1
    },
    {
      "name": "battery_health",
      "label": "Battery SOH",
      "address": 224,
      "function_code": 3,
      "value_type": "U_WORD",
      "unit": "%",
      "multiplier": 1
    },
    {
      "name": "battery_voltage",
      "label": "Battery Voltage",
      "address": 587,
      "function_code": 3,
      "value_type": "U_WORD",
      "unit": "V",
      "multiplier": 0.01
    },
    {
      "name": "battery_temperature",
      "label": "Battery Temperature",
      "address": 586,
      "function_code": 3,
      "value_type": "U_WORD",
      "unit": "°C",
      "multiplier": 0.1
    },
    {
      "name": "grid_voltage",
      "label": "Grid Voltage",
      "address": 598,
      "function_code": 3,
      "value_type": "U_WORD",
      "unit": "V",
      "multiplier": 0.1
    },
    {
      "name": "grid_frequency",
      "label": "Grid Frequency",
      "address": 609,
      "function_code": 3,
      "value_type": "U_WORD",
      "unit": "Hz",
      "multiplier": 0.01
    },
    {
      "name": "run_state",
      "label": "Run State",
      "address": 500,
      "function_code": 3,
      "value_type": "U_WORD",
      "unit": "",
      "multiplier": 1
    }
  ],
  "derived": [
    {
      "name": "pv_total_power",
      "label": "PV Total Power",
      "unit": "W",
      "sum_of": ["pv1_total_power", "pv2_total_power"]
    }
  ]
}
